          "health_status": {
            "type": "string"
          },
          "lifecycle_status": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "icon_ref": {
            "type": "string",
            "nullable": true,
            "description": "Canonical sdkwork-drive node reference.",
            "pattern": "^drive://spaces/[^/]+/nodes/[^/]+$"
          }
        }
      },
      "McpConnectorRecord": {
        "type": "object",
        "additionalProperties": true,
        "required": [
