        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "uuid": {
            "type": "string"
          },
          "server_key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "category_id": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "category_code": {
            "type": "string",
            "nullable": true
          },
          "transport": {
            "type": "string"
