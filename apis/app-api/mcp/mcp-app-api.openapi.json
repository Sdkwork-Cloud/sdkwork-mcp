            "type": "integer",
            "format": "int64"
          },
          "uuid": {
            "type": "string"
          },
          "server_id": {
            "type": "integer",
            "format": "int64"
          },
          "connector_id": {
            "type": "integer",
            "format": "int64"
          },
          "resource_key": {
            "type": "string"
          },
          "uri": {
            "type": "string"
