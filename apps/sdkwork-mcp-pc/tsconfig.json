{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "isolatedModules": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": ["./node_modules/@types/react/jsx-dev-runtime.d.ts"],
      "@sdkwork/iam-app-sdk": [
        "../../../sdkwork-iam/sdks/sdkwork-iam-app-sdk/sdkwork-iam-app-sdk-typescript/generated/server-openapi/src/index.ts"
      ],
      "@sdkwork/iam-backend-sdk": [
        "../../../sdkwork-iam/sdks/sdkwork-iam-backend-sdk/sdkwork-iam-backend-sdk-typescript/generated/server-openapi/src/index.ts"
      ],
      "@sdkwork/auth-pc-react": ["./src/bootstrap/sdkworkAuthPcReactShim.d.ts"],
      "@sdkwork/auth-runtime-pc-react": [
        "../../../sdkwork-iam/apps/sdkwork-iam-pc/packages/sdkwork-auth-runtime-pc-react/src/index.ts"
      ],
      "@sdkwork/core-pc-react": [
        "../../../sdkwork-core/sdkwork-core-pc-react/src/index.ts"
      ],
      "@sdkwork/drive-app-sdk": [
        "../../../sdkwork-drive/sdks/sdkwork-drive-app-sdk/sdkwork-drive-app-sdk-typescript/src/index.ts"
      ],
      "@sdkwork/iam-contracts": [
        "../../../sdkwork-iam/apps/sdkwork-iam-common/packages/sdkwork-iam-contracts/src/index.ts"
      ],
      "@sdkwork/iam-runtime": [
        "../../../sdkwork-iam/apps/sdkwork-iam-common/packages/sdkwork-iam-runtime/src/index.ts"
      ],
      "@sdkwork/runtime-bootstrap": [
        "../../../sdkwork-appbase/packages/common/foundation/sdkwork-runtime-bootstrap/src/index.ts"
      ],
      "@sdkwork/sdk-common": [
        "../../../sdkwork-sdk-commons/sdkwork-sdk-common-typescript/src/index.ts"
      ],
      "@sdkwork/utils": [
        "../../../sdkwork-utils/packages/sdkwork-utils-typescript/src/index.ts"
      ],
      "sdkwork-mcp-app-sdk-generated-typescript/src/*": [
        "../../sdks/sdkwork-mcp-app-sdk/sdkwork-mcp-app-sdk-typescript/generated/server-openapi/src/*"
      ],
      "sdkwork-mcp-backend-sdk-generated-typescript/src/*": [
        "../../sdks/sdkwork-mcp-backend-sdk/sdkwork-mcp-backend-sdk-typescript/generated/server-openapi/src/*"
      ]
    }
  },
  "include": ["src", "packages"]
}
