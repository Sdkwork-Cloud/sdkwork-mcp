{
  "schemaVersion": 1,
  "kind": "sdkwork.database.module",
  "moduleId": "mcp",
  "serviceCode": "MCP",
  "displayName": "SDKWork MCP Database",
  "owner": "mcp-platform",
  "engines": [
    "postgres"
  ],
  "defaultEngine": "postgres",
  "tablePrefix": "ai_mcp_",
  "contractVersion": "1.0.0",
  "baselineStrategy": "baseline-plus-migrations",
  "modules": [],
  "lifecycle": {
    "autoMigrate": true,
    "seedOnBoot": false,
    "defaultSeedLocale": "zh-CN",
    "defaultSeedProfile": "standard",
    "supportedSeedLocales": [
      "zh-CN",
      "en-US"
    ],
    "activeSeedLocales": [
      "zh-CN"
    ],
    "driftCheckIntervalSec": 60
  },
  "paths": {
    "contract": "contract/schema.yaml",
    "migrations": "migrations",
    "seeds": "seeds",
    "driftPolicy": "drift/policy.yaml"
  },
  "spi": {
    "provider": "default",
    "hooks": []
  }
}
