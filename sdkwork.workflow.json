{
  "$schema": "../sdkwork-github-workflow/schemas/sdkwork-workflow.schema.json",
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-mcp",
    "name": "SDKWork MCP",
    "repository": "Sdkwork-Cloud/sdkwork-mcp",
    "sourcePath": ".",
    "configPath": "sdkwork.app.config.json"
  },
  "release": {
    "artifactPrefix": "sdkwork-mcp",
    "defaultVersion": "0.1.0",
    "changelog": {
      "source": "app-manifest",
      "maxCommitSubjects": 50
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-web-framework",
      "repository": "Sdkwork-Cloud/sdkwork-web-framework",
      "refInput": "SDKWORK_WEB_FRAMEWORK_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-database",
      "repository": "Sdkwork-Cloud/sdkwork-database",
      "refInput": "SDKWORK_DATABASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-utils",
      "repository": "Sdkwork-Cloud/sdkwork-utils",
      "refInput": "SDKWORK_UTILS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-drive",
      "repository": "Sdkwork-Cloud/sdkwork-drive",
      "refInput": "SDKWORK_DRIVE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-app-topology",
      "repository": "Sdkwork-Cloud/sdkwork-app-topology",
      "refInput": "SDKWORK_APP_TOPOLOGY_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-iam",
      "repository": "Sdkwork-Cloud/sdkwork-iam",
      "refInput": "SDKWORK_IAM_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-generator",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-generator",
      "refInput": "SDKWORK_SDK_GENERATOR_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.33.0",
    "rust": "stable"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install workspace dependencies",
        "shell": "pwsh",
        "run": "pnpm install --frozen-lockfile || pnpm install --no-frozen-lockfile --config.auto-install-peers=false"
      }
    ],
    "build": [
      {
        "name": "Verify MCP architecture alignment",
        "shell": "pwsh",
        "run": "node tools/check_sdkwork_mcp_architecture_alignment.mjs"
      },
      {
        "name": "Build Rust workspace",
        "shell": "pwsh",
        "run": "cargo build --workspace --release"
      }
    ],
    "package": [
      {
        "name": "Package MCP API server binaries",
        "shell": "pwsh",
        "run": "cargo build --release -p sdkwork-mcp-standalone-gateway"
      },
      {
        "name": "Build MCP PC web bundle",
        "shell": "pwsh",
        "run": "pnpm --dir apps/sdkwork-mcp-pc build"
      },
      {
        "name": "Build MCP H5 web bundle",
        "shell": "pwsh",
        "run": "pnpm --dir apps/sdkwork-mcp-h5 build"
      }
    ],
    "validate": [
      {
        "name": "Validate MCP contracts and architecture",
        "shell": "pwsh",
        "run": "pnpm verify"
      }
    ]
  },
  "targets": [
    {
      "id": "linux-x64-standalone-server-tar-gz",
      "profile": "server",
      "platform": "linux",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "target/release/sdkwork-mcp-standalone-gateway*"
      ],
      "deploymentProfile": "standalone",
      "runtimeTarget": "server"
    },
    {
      "id": "web-universal-cloud-browser-zip",
      "profile": "browser",
      "platform": "web",
      "architecture": "universal",
      "formats": ["zip"],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "apps/sdkwork-mcp-pc/dist/**",
        "apps/sdkwork-mcp-h5/dist/**"
      ],
      "deploymentProfile": "cloud",
      "runtimeTarget": "browser"
    }
  ],
  "security": {
    "artifactAttestations": false,
    "sbomRequired": false,
    "signingRequired": false
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": false,
    "retentionDays": 30
  }
}
